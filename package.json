{
	"name": "obsidian-mapx",
	"version": "0.1.0",
	"description": "Adds map view to Obsidian Bases.",
	"keywords": [
		"bases",
		"maps",
		"obsidian",
		"plugin"
	],
	"license": "MIT",
	"author": "Obsidian",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"dev": "node scripts/generate-rtl-plugin.mjs && rolldown -c --watch",
		"build": "node scripts/generate-rtl-plugin.mjs && tsc -noEmit -skipLibCheck && NODE_ENV=production rolldown -c",
		"link": "node scripts/link-vault.mjs",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"check": "pnpm run lint && pnpm run fmt:check && pnpm run build",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"dependencies": {
		"maplibre-gl": "5.8.0"
	},
	"devDependencies": {
		"@mapbox/mapbox-gl-rtl-text": "^0.3.0",
		"obsidian": "latest",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.36.0",
		"rolldown": "^1.1.0",
		"typescript": "5.9.3"
	},
	"packageManager": "pnpm@11.10.0",
	"authorUrl": "https://obsidian.md"
}
